# --- Model provider (pick ONE) ---

# Option A: call OpenAI directly. Simplest for local dev.
OPENAI_API_KEY=

# Option B: route through the Vercel AI Gateway instead (used automatically
# when deployed on Vercel; leave OPENAI_API_KEY blank to use this path).
AI_GATEWAY_API_KEY=

# Optional: override the extraction model. Must be vision-capable.
# Default with OpenAI:  gpt-4o
# Default with Gateway: anthropic/claude-haiku-4.5
# EXTRACTION_MODEL=gpt-4o
